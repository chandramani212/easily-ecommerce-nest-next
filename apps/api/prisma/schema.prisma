generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

enum ContactStatus {
  NEW
  READ
  REPLIED
}

enum TierPriceType {
  FIXED
  PERCENTAGE
}

enum SupplierKind {
  REST
  FILE_FEED
}

enum SupplierAuthType {
  NONE
  API_KEY
  BASIC
  BEARER
  OAUTH2_CLIENT_CREDENTIALS
}

enum SupplierImportFormat {
  JSON
  XML
  CSV
}

enum SupplierImportRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum SupplierImportTrigger {
  SCHEDULE
  MANUAL
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  role         UserRole     @default(STAFF)
  uploads      MediaAsset[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  products    Product[]  @relation("ProductCategories")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  sku              String   @unique
  shortDescription String   @default("") @db.VarChar(500)
  description      String   @default("")
  basePrice        Decimal  @db.Decimal(12, 2)
  sellingPrice     Decimal  @db.Decimal(12, 2)
  images           String[] @default([])
  attributes       Json     @default("[]")
  active           Boolean  @default(true)

  categories Category[] @relation("ProductCategories")

  relatedTo Product[] @relation("RelatedProducts")
  relatedBy Product[] @relation("RelatedProducts")

  tierPrices    TierPrice[]
  orderItems    OrderItem[]
  supplierLinks SupplierProductLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MediaAsset {
  id           String   @id @default(cuid())
  filename     String   @unique
  originalName String
  url          String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  alt          String?
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model TierPrice {
  id          String        @id @default(cuid())
  productId   String
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  minQuantity Int
  type        TierPriceType @default(FIXED)
  // FIXED: per-unit price in store currency.
  // PERCENTAGE: 0-100, applied off Product.sellingPrice via resolveTierUnitPrice().
  price       Decimal       @db.Decimal(12, 2)

  @@unique([productId, minQuantity])
}

model Customer {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  company   String?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(12, 2)
  shipping        Decimal     @db.Decimal(12, 2) @default(0)
  tax             Decimal     @db.Decimal(12, 2) @default(0)
  total           Decimal     @db.Decimal(12, 2)
  shippingAddress Json?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name      String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  lineTotal Decimal @db.Decimal(12, 2)
}

model Inquiry {
  id          String        @id @default(cuid())
  inquiryType String
  productName String?
  name        String
  email       String
  phone       String?
  company     String?
  quantity    String?
  message     String?
  status      InquiryStatus @default(NEW)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ContactMessage {
  id        String        @id @default(cuid())
  firstName String
  lastName  String
  email     String
  subject   String?
  message   String
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Settings {
  id         Int      @id @default(1)
  smtpHost   String   @default("")
  smtpPort   Int      @default(587)
  smtpUser   String   @default("")
  smtpPass   String   @default("")
  smtpFrom   String   @default("")
  smtpSecure Boolean  @default(false)
  notifyTo   String   @default("")
  updatedAt  DateTime @updatedAt
}

model Supplier {
  id               String           @id @default(cuid())
  name             String
  kind             SupplierKind     @default(REST)
  baseUrl          String?
  authType         SupplierAuthType @default(NONE)
  // AES-256-GCM encrypted JSON blob holding credentials. Shape depends on authType.
  // Use SecretsCipher to encrypt/decrypt; never return raw to clients.
  authSecret       String?
  defaultMarkupPct Decimal          @default(0) @db.Decimal(6, 2)
  notes            String           @default("")
  active           Boolean          @default(true)

  imports SupplierImport[]
  links   SupplierProductLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupplierImport {
  id                    String               @id @default(cuid())
  supplierId            String
  supplier              Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name                  String
  format                SupplierImportFormat @default(JSON)
  // Source config (REST only). FILE_FEED imports ignore these and use sampleFile/runs upload.
  endpoint              String?
  httpMethod            String               @default("GET")
  headers               Json                 @default("{}")
  body                  String?
  // JSONPath ($.data.products) or XPath-ish (//products/product) selecting the records array.
  recordsPath           String               @default("$")
  // Mapping spec (see runner/mapper.service.ts for shape).
  mapping               Json                 @default("{}")
  // Markup spec: { kind: "percent"|"fixed", value: number, appliesTo: ("basePrice"|"sellingPrice")[] }
  markup                Json                 @default("{}")
  // 5-field cron expression. Empty disables auto-run; manual triggers still work.
  cron                  String               @default("")
  active                Boolean              @default(true)
  // Optional sample file uploaded for FILE_FEED dry-runs / cached body for sample fetches.
  sampleFilename        String?
  sampleMime            String?
  // When true and a previously-linked product is missing from a successful run, deactivate it.
  autoDeactivateMissing Boolean              @default(false)

  lastRunAt    DateTime?
  lastStatus   SupplierImportRunStatus?
  lastRunId    String?

  runs SupplierImportRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
}

model SupplierImportRun {
  id          String                  @id @default(cuid())
  importId    String
  import      SupplierImport          @relation(fields: [importId], references: [id], onDelete: Cascade)
  status      SupplierImportRunStatus @default(RUNNING)
  triggeredBy SupplierImportTrigger   @default(MANUAL)
  startedAt   DateTime                @default(now())
  finishedAt  DateTime?
  // Aggregate counters incremented as records are processed.
  created     Int                     @default(0)
  updated     Int                     @default(0)
  skipped     Int                     @default(0)
  failed      Int                     @default(0)
  // Array of { record: number, externalId?: string, error: string }
  errors      Json                    @default("[]")

  @@index([importId, startedAt])
}

model SupplierProductLink {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  externalId String
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Last time this link was seen by a successful sync. Used by autoDeactivateMissing.
  lastSeenAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([supplierId, externalId])
  @@index([productId])
}
