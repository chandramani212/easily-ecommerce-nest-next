generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

enum ContactStatus {
  NEW
  READ
  REPLIED
}

enum TierPriceType {
  FIXED
  PERCENTAGE
}

enum SourceKind {
  REST
  FILE_FEED
  ASI_CENTRAL
}

enum SourceAuthType {
  NONE
  API_KEY
  BASIC
  BEARER
  OAUTH2_CLIENT_CREDENTIALS
  ASI_MEMBER_AUTH
}

enum SourceImportFormat {
  JSON
  XML
  CSV
}

enum SourceImportRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum SourceImportTrigger {
  SCHEDULE
  MANUAL
}

/// How a Supplier (the real-world company you order from) was captured.
/// MANUAL — typed in by an admin on a direct Source.
/// FEED   — extracted from aggregator import rows during a run.
enum SupplierOrigin {
  MANUAL
  FEED
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  role         UserRole     @default(STAFF)
  uploads      MediaAsset[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  /// Wide hero/banner image shown at the top of the category page.
  bannerImage String?
  /// Optional long-form body text shown on the category page.
  content     String?    @db.Text
  /// When false, the category is hidden from the storefront (nav, home, listing,
  /// and its own page). Admin always sees every category regardless.
  active      Boolean    @default(true)
  /// Manual display order among siblings (same parent). Lower sorts first; name
  /// breaks ties. Set via PATCH /categories/reorder from the admin.
  sortOrder   Int        @default(0)
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  products    Product[]  @relation("ProductCategories")

  // Reverse side of source→curated mapping. A curated Category can be the
  // target of many source-category mappings (e.g. ASI "Bags" and ASI
  // "Tote Bags" can both map to your single curated "Bags & Totes").
  sourceCategoryMappings SourceCategory[] @relation("SourceCategoryToCategory")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  // Your own website SKU. DB-generated default (EB-000001, EB-000002, …) via the
  // `product_sku_seq` sequence, so every insert path gets one for free; admins may
  // override it per product. This is what the storefront shows.
  sku              String   @unique @default(dbgenerated("('EB-'::text || lpad((nextval('product_sku_seq'::regclass))::text, 6, '0'::text))"))
  // Supplier/API SKU mapped from the source feed. Null for products created
  // directly in the admin. Used for import reconciliation, dedupe and reordering.
  externalSku      String?  @unique
  shortDescription String   @default("") @db.VarChar(500)
  description      String   @default("")
  basePrice        Decimal  @db.Decimal(12, 2)
  sellingPrice     Decimal  @db.Decimal(12, 2)
  images           String[] @default([])
  attributes       Json     @default("[]")
  active           Boolean  @default(true)

  // SEO overrides for the product page. Empty = fall back to name/description.
  metaTitle       String  @default("")
  metaDescription String  @default("")
  ogImage         String? // URL (media library) for social share cards.
  keywords        String  @default("")

  categories Category[] @relation("ProductCategories")
  // Source categories this product was imported under (durable link; curated
  // categories are derived from these + the source→curated mapping).
  sourceCategories SourceCategory[] @relation("ProductSourceCategories")

  relatedTo Product[] @relation("RelatedProducts")
  relatedBy Product[] @relation("RelatedProducts")

  tierPrices  TierPrice[]
  orderItems  OrderItem[]
  sourceLinks SourceProductLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MediaAsset {
  id           String   @id @default(cuid())
  filename     String   @unique
  originalName String
  url          String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  alt          String?
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  /// Original remote URL this asset was downloaded from (set by the source
  /// import runner via MediaService.downloadFromUrl). Used to dedupe across
  /// imports — same source URL → reuse the existing asset.
  sourceUrl    String?  @unique
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model TierPrice {
  id          String        @id @default(cuid())
  productId   String
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  minQuantity Int
  type        TierPriceType @default(FIXED)
  // FIXED: per-unit price in store currency.
  // PERCENTAGE: 0-100, applied off Product.sellingPrice via resolveTierUnitPrice().
  price       Decimal       @db.Decimal(12, 2)

  @@unique([productId, minQuantity])
}

model Customer {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  company   String?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(12, 2)
  shipping        Decimal     @default(0) @db.Decimal(12, 2)
  tax             Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  shippingAddress Json?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name      String
  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  lineTotal Decimal  @db.Decimal(12, 2)
}

model Inquiry {
  id          String        @id @default(cuid())
  inquiryType String
  productName String?
  // The product this lead is about, captured from the storefront enquiry link.
  productSku   String?
  productImage String?
  name        String
  email       String
  phone       String?
  company     String?
  quantity    String?
  message     String?
  status      InquiryStatus @default(NEW)

  // Lead-source attribution, derived server-side from UTM params + referrer.
  // `source` is the classified bucket; `organic` is the headline split
  // (organic = not from paid/email marketing). Raw signals kept for context.
  source   String  @default("direct") // organic | paid | social | referral | email | direct
  organic  Boolean @default(true)
  // Specific platform the lead came from (google, yahoo, facebook, bing, ...),
  // derived from utm_source or the referrer host. Empty for direct.
  provider String  @default("")
  medium   String  @default("") // raw utm_medium
  campaign String  @default("") // raw utm_campaign
  referrer String  @default("") // referring URL/host

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([source])
  @@index([createdAt])
}

model ContactMessage {
  id        String        @id @default(cuid())
  firstName String
  lastName  String
  email     String
  subject   String?
  message   String
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Settings {
  id         Int      @id @default(1)
  smtpHost   String   @default("")
  smtpPort   Int      @default(587)
  smtpUser   String   @default("")
  smtpPass   String   @default("")
  smtpFrom   String   @default("")
  smtpSecure Boolean  @default(false)
  notifyTo   String   @default("")
  updatedAt  DateTime @updatedAt
}

model Source {
  id               String         @id @default(cuid())
  name             String
  kind             SourceKind     @default(REST)
  baseUrl          String?
  authType         SourceAuthType @default(NONE)
  // AES-256-GCM encrypted JSON blob holding credentials. Shape depends on authType.
  // Use SecretsCipher to encrypt/decrypt; never return raw to clients.
  authSecret       String?
  defaultMarkupPct Decimal        @default(0) @db.Decimal(6, 2)
  notes            String         @default("")
  active           Boolean        @default(true)

  imports    SourceImport[]
  links      SourceProductLink[]
  categories SourceCategory[]
  // The real-world supplier companies behind this source. Direct sources have
  // one (origin MANUAL); aggregators accumulate many (origin FEED) as imports run.
  suppliers  Supplier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SourceImport {
  id                    String             @id @default(cuid())
  sourceId              String
  source                Source             @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  name                  String
  format                SourceImportFormat @default(JSON)
  // Source config (REST only). FILE_FEED imports ignore these and use sampleFile/runs upload.
  endpoint              String?
  httpMethod            String             @default("GET")
  headers               Json               @default("{}")
  body                  String?
  // JSONPath ($.data.products) or XPath-ish (//products/product) selecting the records array.
  recordsPath           String             @default("$")
  // Mapping spec (see runner/mapper.service.ts for shape).
  mapping               Json               @default("{}")
  // Markup spec: { kind: "percent"|"fixed", value: number, appliesTo: ("basePrice"|"sellingPrice")[] }
  markup                Json               @default("{}")
  // 5-field cron expression. Empty disables auto-run; manual triggers still work.
  cron                  String             @default("")
  active                Boolean            @default(true)
  // Optional sample file uploaded for FILE_FEED dry-runs / cached body for sample fetches.
  sampleFilename        String?
  sampleMime            String?
  // When true and a previously-linked product is missing from a successful run, deactivate it.
  autoDeactivateMissing Boolean            @default(false)

  lastRunAt  DateTime?
  lastStatus SourceImportRunStatus?
  lastRunId  String?

  runs SourceImportRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceId])
}

model SourceImportRun {
  id          String                @id @default(cuid())
  importId    String
  import      SourceImport          @relation(fields: [importId], references: [id], onDelete: Cascade)
  status      SourceImportRunStatus @default(RUNNING)
  triggeredBy SourceImportTrigger   @default(MANUAL)
  startedAt   DateTime              @default(now())
  finishedAt  DateTime?
  // Total records for this run — the denominator for progress. Set as soon as
  // the id list is known (before details finish downloading); 0 before that.
  total       Int                   @default(0)
  // Detail records downloaded so far during the fetch phase. Lets the UI show
  // download progress before processing begins.
  fetched     Int                   @default(0)
  // Aggregate counters incremented as records are processed.
  created     Int                   @default(0)
  updated     Int                   @default(0)
  skipped     Int                   @default(0)
  failed      Int                   @default(0)
  // Array of { record: number, externalId?: string, error: string }
  errors      Json                  @default("[]")

  @@index([importId, startedAt])
}

model SourceProductLink {
  id         String    @id @default(cuid())
  sourceId   String
  source     Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  // The real supplier company this product came from. Set during import from the
  // feed's vendor mapping (aggregators) or the source's manual supplier (direct).
  // Nullable: legacy links and sources without supplier info carry none.
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  externalId String
  productId  String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Last time this link was seen by a successful sync. Used by autoDeactivateMissing.
  lastSeenAt DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceId, externalId])
  @@index([productId])
  @@index([supplierId])
}

/// A real-world supplier company — the entity you actually phone or reorder
/// from. Distinct from `Source`, which is the integration/connection the
/// catalog is imported through. A direct source has exactly one Supplier (typed
/// in by an admin, origin MANUAL); an aggregator source accumulates many
/// Suppliers (origin FEED) as products are imported, each carrying its own
/// contact details extracted from the feed.
model Supplier {
  id         String         @id @default(cuid())
  sourceId   String
  source     Source         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  origin     SupplierOrigin @default(MANUAL)
  // Vendor identity within an aggregator feed; used to upsert across runs.
  // Empty string for MANUAL suppliers (one per direct source).
  externalId String         @default("")
  name       String
  phone      String?
  altPhone   String?
  tollFree   String?
  website    String?
  active     Boolean        @default(true)

  productLinks SourceProductLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceId, externalId])
  @@index([sourceId])
}

/// Source-side categories, captured verbatim during import. Each row holds
/// the source's own externalId + name + optional parent externalId so the
/// source hierarchy can be reconstructed for the admin.
///
/// `categoryId` is optional: when an admin maps a source category to one of
/// their curated `Category` rows, products imported under that source
/// category are attached to the curated one. Until that mapping exists,
/// imported products don't get a category from this source — keeping the
/// storefront category tree clean.
model SourceCategory {
  id               String    @id @default(cuid())
  sourceId         String
  source           Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId       String
  name             String
  parentExternalId String?
  categoryId       String?
  category         Category? @relation("SourceCategoryToCategory", fields: [categoryId], references: [id], onDelete: SetNull)

  // Products that belong to this source category (stored during import/backfill).
  // The durable "which product is in which source category" link — lets curated
  // categories be re-derived locally when the source→curated mapping changes,
  // with no ASI calls. See [[project_category_mapping]].
  products Product[] @relation("ProductSourceCategories")

  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([sourceId, externalId])
  @@index([sourceId, categoryId])
}

/// Editable storefront page content + SEO. One row per well-known `slug`
/// ("home", "about", "contact"). `content` is a slug-specific JSON blob
/// (hero slides for home; fixed sections for about/contact) consumed by the
/// public web app; the SEO columns drive each page's <head> metadata.
model Page {
  id      String @id @default(cuid())
  slug    String @unique
  title   String @default("")
  content Json   @default("{}")

  // SEO
  metaTitle       String  @default("")
  metaDescription String  @default("")
  ogImage         String?
  keywords        String  @default("")
  canonicalUrl    String  @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
